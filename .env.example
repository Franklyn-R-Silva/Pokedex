# Copie para .env (que é ignorado pelo git) e preencha com os valores reais.

# Supabase (Project URL + chave publishable/anon — a segurança real é o RLS)
VITE_SUPABASE_URL=https://SEU-PROJETO.supabase.co
VITE_SUPABASE_PUBLISHABLE_KEY=sua-chave-anon-publishable

# Opcional: chave da Pokémon TCG API (aumenta o limite de requisições)
VITE_POKEMONTCG_KEY=
